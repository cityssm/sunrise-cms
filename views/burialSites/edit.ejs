<%- include('../_header'); -%>

<nav class="breadcrumb">
  <ul>
    <li><a href="<%= urlPrefix %>/dashboard"><%= t('home') %></a></li>
    <li>
      <a href="<%= urlPrefix %>/burialSites">
        <span class="icon is-small"><i class="fa-solid fa-map-pin"></i></span>
        <span><%= t('cemeteries.burialSites') %></span>
      </a>
    </li>
    <% if (!isCreate) { %>
    <li>
      <a href="<%= urlPrefix %>/burialSites/<%= burialSite.burialSiteId %>">
        <%= burialSite.burialSiteName %>
      </a>
    </li>
    <% } %>
    <li class="is-active">
      <a href="#" aria-current="page">
        <%= (isCreate) ? t('cemeteries.createNewBurialSite') : t('cemeteries.updateBurialSite') %>
      </a>
    </li>
  </ul>
</nav>

<h1 class="title is-1">
  <%= (isCreate) ? t('cemeteries.createNewBurialSite') : burialSite.burialSiteName %>
</h1>

<% if (isCreate && burialSiteTypes.length === 0) { %>
<div class="message is-warning">
  <div class="message-body">
    <p>
      There are currently no burial site types available.
    </p>
    <% if (user.userProperties.isAdmin) { %>
    <p class="has-text-right">
      <a class="button is-warning" href="<%= urlPrefix %>/admin/burialSiteTypes">
        <span class="icon"><i class="fa-solid fa-gear"></i></span>
        <span><%= t('admin:burialSiteTypeManagement') %></span>
      </a>
    </p>
    <% } %>
  </div>
</div>
<% } %>

<div class="columns is-vcentered is-fixed-bottom has-background-white has-shadow is-hidden-print">
  <div class="column">
    <% if (!isCreate) { %>
    <span class="has-text-weight-bold">
      <%= burialSite.burialSiteName %>
    </span>
    <% } %>
  </div>

  <div class="column is-narrow has-text-right">
    <div class="buttons is-right">
      <% if (isCreate) { %>
      <a class="button is-danger is-light" href="<%= urlPrefix %>/burialSites">
        Cancel
      </a>
      <button class="button is-primary is-light" type="submit" form="form--burialSite">
        <span class="icon is-small"><i class="fa-solid fa-save"></i></span>
        <span>
          <%= t('cemeteries.createBurialSite') %>
        </span>
      </button>
      <% } else { %>
      <div class="field has-addons">
        <div class="control">
          <button class="button is-primary is-light" type="submit" form="form--burialSite">
            <span class="icon is-small"><i class="fa-solid fa-save"></i></span>
            <span>
              <%= t('cemeteries.updateBurialSite') %>
            </span>
          </button>
        </div>
        <div class="control">
          <div class="dropdown is-right is-up" data-cy="dropdown--moreOptions">
            <div class="dropdown-trigger">
              <button
                class="button is-primary is-light"
                type="button"
                title="<%= t('moreOptions') %>"
                aria-haspopup="true"
              >
                <span class="icon is-small">
                  <i class="fa-solid fa-angle-up"></i>
                </span>
              </button>
            </div>
            <div class="dropdown-menu">
              <div class="dropdown-content has-text-left">
                <a class="dropdown-item" id="button--deleteBurialSite" href="#">
                  <span class="icon"><i class="fa-solid fa-trash has-text-danger"></i></span>
                  <span>Delete Burial Site</span>
                </a>
                <% if (configFunctions.getConfigProperty('settings.auditLog.enabled')) { %>
                <hr class="dropdown-divider" />
                <a
                  class="dropdown-item is-view-audit-log-button"
                  data-main-record-type="burialSite"
                  data-main-record-id="<%= burialSite.burialSiteId %>"
                  data-record-create-user="<%= burialSite.recordCreate_userName %>"
                  data-record-create-millis="<%= burialSite.recordCreate_timeMillis %>"
                  data-record-update-user="<%= burialSite.recordUpdate_userName %>"
                  data-record-update-millis="<%= burialSite.recordUpdate_timeMillis %>"
                  data-audit-log-url="<%= urlPrefix %>/burialSites/doGetRecordAuditLog"
                  href="#"
                >
                  <span class="icon"><i class="fa-solid fa-clock-rotate-left"></i></span>
                  <span>Audit Log</span>
                </a>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </div>
      <% } %>
    </div>
  </div>
  
</div>

<% if (isCreate) { %>
<div class="message is-info">
  <p class="message-body">
    Note that if you are creating a range of burial sites, the
    <a href="<%= urlPrefix %>/burialSites/creator">Burial Site Range Creator tool</a>
    can help streamline the process.
  </p>
</div>
<% } %>

<form class="mb-5" id="form--burialSite">
  <input
    id="burialSite--burialSiteId"
    name="burialSiteId"
    type="hidden"
    value="<%= isCreate ? '' : burialSite.burialSiteId %>"
  />

  <div class="panel">
    <div class="panel-block is-block">
      <div class="columns">
        <div class="column is-8">
          <div class="columns">
            <div class="column">
              <label class="label" for="burialSite--cemeteryId">Cemetery</label>
              <div class="field has-addons">
                <div class="control is-expanded">
                  <div class="select is-fullwidth">
                    <select
                      class="<%= (isCreate ? '' : 'is-readonly') %>"
                      id="burialSite--cemeteryId"
                      name="cemeteryId"
                      data-autofocus="<%= (isCreate ? 'autofocus' : '') %>"
                    >
                      <option
                        data-disabled="<%= (!isCreate && burialSite.cemeteryId ? 'disabled' : '') %>"
                        value=""
                      >
                        (<%= t('cemeteries.noCemeterySelected') %>)
                      </option>

                      <% let cemeteryIsFound = false; %>
                      <% for (const cemetery of cemeteries) { %>
                      <%
                        if (burialSite.cemeteryId === cemetery.cemeteryId) {
                          cemeteryIsFound = true;
                        }
                      %>
                      <option
                        data-cemetery-key="<%= cemetery.cemeteryKey %>"
                        data-selected="<%= (burialSite.cemeteryId === cemetery.cemeteryId ? 'selected' : '') %>"
                        data-disabled="<%= (!isCreate && burialSite.cemeteryId !== cemetery.cemeteryId ? 'disabled' : '') %>"
                        value="<%= cemetery.cemeteryId %>"
                      >
                        <%= cemetery.cemeteryName || ('(' + t('cemeteries.noName') + ')')  %>
                      </option>
                      <% } %>

                      <% if (burialSite.cemeteryId && !cemeteryIsFound) { %>
                      <option value="<%= burialSite.cemeteryId %>" selected>
                        <%= burialSite.cemeteryName %>
                      </option>
                      <% } %>
                    </select>
                  </div>
                </div>
                <div class="control">
                  <button class="button is-unlock-field-button" type="button" title="Unlock Field">
                    <span class="icon"><i class="fa-solid fa-unlock"></i></span>
                  </button>
                </div>
              </div>
            </div>
            <div class="column">
              <label class="label" for="burialSite--burialSiteTypeId">
                Burial Site Type
              </label>
              <div class="field has-addons">
                <div class="control is-expanded">
                  <div class="select is-fullwidth">
                    <select
                      class="<%= isCreate ? '' : 'is-readonly' %>"
                      id="burialSite--burialSiteTypeId"
                      name="burialSiteTypeId"
                      required
                    >
                      <% if (isCreate) { %>
                      <option data-body-capacity-max="<%= settingFunctions.getSettingValue('burialSiteTypes.bodyCapacityMaxDefault') %>"
                        data-cremated-capacity-max="<%= settingFunctions.getSettingValue('burialSiteTypes.crematedCapacityMaxDefault') %>"
                        value="">
                        (Select a Type)
                      </option>
                      <% } %>

                      <% let typeIsFound = false; %>
                      <% for (const burialSiteType of burialSiteTypes) { %>
                      <%
                        if (burialSite.burialSiteTypeId === burialSiteType.burialSiteTypeId) {
                          typeIsFound = true;
                        }
                      %>
                      <option
                        data-body-capacity-max="<%= burialSiteType.bodyCapacityMax %>"
                        data-cremated-capacity-max="<%= burialSiteType.crematedCapacityMax %>"
                        data-selected="<%= (burialSite.burialSiteTypeId === burialSiteType.burialSiteTypeId ? 'selected' : '') %>"
                        data-disabled="<%= (!isCreate && burialSite.burialSiteTypeId !== burialSiteType.burialSiteTypeId ? 'disabled' : '') %>"
                        value="<%= burialSiteType.burialSiteTypeId %>"
                      >
                        <%= burialSiteType.burialSiteType %>
                      </option>
                      <% } %>
                      <% if (burialSite.burialSiteTypeId && !typeIsFound) { %>
                      <option
                        data-body-capacity-max="<%= burialSite.bodyCapacityMax %>"
                        data-cremated-capacity-max="<%= burialSite.crematedCapacityMax %>"
                        value="<%= burialSite.burialSiteTypeId %>"
                        selected
                      >
                        <%= burialSite.burialSiteType %>
                      </option>
                      <% } %>
                    </select>
                  </div>
                </div>
                <div class="control">
                  <button class="button is-unlock-field-button" type="button" title="Unlock Field">
                    <span class="icon"><i class="fa-solid fa-unlock"></i></span>
                  </button>
                </div>
              </div>
            </div>
          </div>

          <%
          const burialSiteNameSegments = configFunctions.getConfigProperty('settings.burialSites.burialSiteNameSegments')
          %>
          <label class="label" for="burialSite--burialSiteNameSegment1">
            Burial Site Name
          </label>
          <div class="field has-addons">
            <% if (burialSiteNameSegments.includeCemeteryKey ?? false) { %>
            <p class="control">
              <span class="button is-static">
                <span id="burialSite--cemeteryKey"><%- burialSite.cemeteryKey ?? '&nbsp;' %></span>
                <% if ((burialSiteNameSegments.separator ?? '') !== '') { %>
                <%= burialSiteNameSegments.separator %>
                <% } %>
              </span>
            </p>
            <% } %>
            <% for (let segmentIndex = 1; segmentIndex <= 5; segmentIndex += 1) { %>
            <%
            const segmentIndexString = segmentIndex.toString();
            const segment = burialSiteNameSegments.segments[segmentIndexString];
            %>
            <% if (segment?.isAvailable ?? false) { %>
            <% if (segmentIndex !== 1 && (burialSiteNameSegments.separator ?? '') !== '') { %>
            <p class="control">
              <span class="button is-static">
                <%= burialSiteNameSegments.separator %>
              </span>
            </p>
            <% } %>
            <% if ((segment.prefix ?? '') !== '') { %>
            <p class="control">
              <span class="button is-static">
                <%= segment.prefix %>
              </span>
            </p>
            <% } %>
            <div class="control"
              title="<%= segment.label ?? '' %>">

              <input
                class="input"
                id="burialSite--burialSiteNameSegment<%= segmentIndexString %>"
                name="burialSiteNameSegment<%= segmentIndexString %>"
                data-required="<%= (segment.isRequired ?? false) ? 'required' : '' %>"
                type="text"
                value="<%= burialSite[`burialSiteNameSegment${segmentIndex}`] %>"
                minlength="<%= Math.max(Math.min(segment.minLength ?? 1, 20), 1) %>"
                maxlength="<%= Math.max(Math.min(segment.maxLength ?? 20, 20), 1) %>"
                aria-label="<%= segment.label ?? '' %>"
                placeholder="<%= segment.label ?? '' %>"
              />
            </div>
            <% if ((segment.suffix ?? '') !== '') { %>
            <p class="control">
              <span class="button is-static">
                <%= segment.suffix %>
              </span>
            </p>
            <% } %>
            <% } %>
            <% } %>
          </div>

          <div class="columns">
            <div class="column">
              <div class="field">
                <label class="label" for="burialSite--bodyCapacity">Body Capacity</label>
                <div class="control">
                  <input
                    class="input has-text-right"
                    id="burialSite--bodyCapacity"
                    name="bodyCapacity"
                    type="number"
                    value="<%= burialSite.bodyCapacity %>"
                    min="0"
                    max="<%= burialSite.bodyCapacityMax ?? settingFunctions.getSettingValue('burialSiteTypes.bodyCapacityMaxDefault') %>"
                    step="1"
                    placeholder="<%= burialSite.bodyCapacityMax ?? settingFunctions.getSettingValue('burialSiteTypes.bodyCapacityMaxDefault') %>"
                    onwheel="return false"
                  />
                </div>
              </div>
            </div>
            <div class="column">
              <div class="field">
                <label class="label" for="burialSite--crematedCapacity">Cremated Capacity</label>
                <div class="control">
                  <input
                    class="input has-text-right"
                    id="burialSite--crematedCapacity"
                    name="crematedCapacity"
                    type="number"
                    value="<%= burialSite.crematedCapacity %>"
                    min="0"
                    max="<%= burialSite.crematedCapacityMax ?? settingFunctions.getSettingValue('burialSiteTypes.crematedCapacityMaxDefault') %>"
                    step="1"
                    placeholder="<%= burialSite.crematedCapacityMax ?? settingFunctions.getSettingValue('burialSiteTypes.crematedCapacityMaxDefault') %>"
                    onwheel="return false"
                  />
                </div>
              </div>
            </div>
            <div class="column">
              <label class="label" for="burialSite--burialSiteStatusId">
                Burial Site Status
              </label>
              <div class="field">
                <div class="control">
                  <div class="select is-fullwidth">
                    <select id="burialSite--burialSiteStatusId" name="burialSiteStatusId">
                      <option value="">(<%= t('cemeteries.noStatus') %>)</option>

                      <% let statusIsFound = false; %>
                      <% for (const burialSiteStatus of burialSiteStatuses) { %>
                      <%
                        if (burialSite.burialSiteStatusId === burialSiteStatus.burialSiteStatusId) {
                          statusIsFound = true;
                        }
                      %>
                      <option
                        data-selected="<%= (burialSite.burialSiteStatusId === burialSiteStatus.burialSiteStatusId ? 'selected' : '') %>"
                        value="<%= burialSiteStatus.burialSiteStatusId %>"
                      >
                        <%= burialSiteStatus.burialSiteStatus %>
                      </option>
                      <% } %>

                      <% if (burialSite.burialSiteStatusId && !statusIsFound) { %>
                      <option value="<%= burialSite.burialSiteStatusId %>" selected>
                        <%= burialSite.burialSiteStatus %>
                      </option>
                      <% } %>
                    </select>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="column">
          <div id="container--burialSiteFields">
            <% if (isCreate) { %>
            <div class="message is-info">
              <p class="message-body">
                Select the burial site type to load the available fields.
              </p>
            </div>
            <% } else if (burialSite.burialSiteFields.length === 0) { %>
            <div class="message is-info">
              <p class="message-body">
                The current burial site type has no additional fields.
              </p>
            </div>
            <% } else { %>
            <% let burialSiteTypeFieldIds = ""; %>
            <% for (const burialSiteField of burialSite.burialSiteFields) { %>
            <% burialSiteTypeFieldIds += "," + burialSiteField.burialSiteTypeFieldId; %>
            <!-- eslint-disable html/no-duplicate-id -->
            <div class="field">
              <label class="label" for="burialSite--fieldValue_<%= burialSiteField.burialSiteTypeFieldId %>">
                <%= burialSiteField.burialSiteTypeField %>
              </label>
              <div class="control">
                <% if (burialSiteField.fieldType === 'select' || (burialSiteField.fieldValues ?? '') !== "") { %>

                <%
                  const fieldValues = burialSiteField.fieldValues.split("\n");
                  let valueFound = false;
                %>
                <div class="select is-fullwidth">
                  <select id="burialSite--fieldValue_<%= burialSiteField.burialSiteTypeFieldId %>"
                    name="fieldValue_<%= burialSiteField.burialSiteTypeFieldId %>">
                    <% if (!burialSiteField.isRequired || burialSiteField.fieldValue === "") { %>
                    <option value="">(<%= t('contracts.notSet') %>)</option>
                    <% } %>

                    <% for (const fieldValue of fieldValues) { %>
                    <%
                      if (fieldValue === burialSiteField.fieldValue) {
                        valueFound = true;
                      }
                    %>
                    <option
                      data-selected="<%= (fieldValue === burialSiteField.fieldValue ? 'selected' : '') %>"
                      value="<%= fieldValue %>"
                    >
                      <%= fieldValue %>
                    </option>
                    <% } %>

                    <% if (!valueFound && burialSiteField.fieldValue !== "") { %>
                    <option value="<%= burialSiteField.fieldValue %>" selected>
                      <%= burialSiteField.fieldValue %>
                    </option>
                    <% } %>
                  </select>
                </div>
                <% } else { %>
                <!-- eslint-disable html/no-ineffective-attrs -->
                <input
                  class="input"
                  id="burialSite--fieldValue_<%= burialSiteField.burialSiteTypeFieldId %>"
                  name="fieldValue_<%= burialSiteField.burialSiteTypeFieldId %>"
                  data-pattern="<%= burialSiteField.pattern %>"
                  data-required="<%= burialSiteField.isRequired ? 'required' : '' %>"
                  type="<%= burialSiteField.fieldType %>"
                  value="<%= burialSiteField.fieldValue %>"
                  minlength="<%= burialSiteField.minLength %>"
                  maxlength="<%= burialSiteField.maxLength %>"
                />
                <!-- eslint-enable html/no-ineffective-attrs -->
                <% } %>
              </div>
            </div>
            <!-- eslint-enable html/no-duplicate-id -->
            <% } %>
            <input
              id="burialSite--burialSiteTypeFieldIds"
              name="burialSiteTypeFieldIds"
              type="hidden"
              value="<%= burialSiteTypeFieldIds.slice(1) %>"
            />
            <% } %>
          </div>
        </div>
      </div>
      
    </div>
  </div>

  <div class="columns">
    <div class="column">
      <div class="panel">
        <div class="panel-heading">
          <div class="level is-mobile">
            <div class="level-left">
              <div class="level-item">
                <h2 class="title is-5 has-text-weight-bold has-text-white">Geographic Location</h2>
              </div>
            </div>
            <div class="level-right">
              <div class="level-item">
                <button class="button is-small" id="button--selectCoordinate" type="button">
                  <span class="icon"><i class="fa-solid fa-map-marked-alt"></i></span>
                  <span>Select Coordinate</span>
                </button>
              </div>
            </div>
          </div>
        </div>
        <div class="panel-block is-block">
          <div class="field">
            <label class="label" for="burialSite--burialSiteLatitude">Latitude</label>
            <div class="control">
              <input
                class="input"
                id="burialSite--burialSiteLatitude"
                name="burialSiteLatitude"
                type="number"
                value="<%= burialSite.burialSiteLatitude %>"
                min="<%= configFunctions.getConfigProperty('settings.latitudeMin') %>"
                max="<%= configFunctions.getConfigProperty('settings.latitudeMax') %>"
                step="0.00000001"
                onwheel="return false"
              />
            </div>
          </div>
          <div class="field">
            <label class="label" for="burialSite--burialSiteLongitude">Longitude</label>
            <div class="control">
              <input
                class="input"
                id="burialSite--burialSiteLongitude"
                name="burialSiteLongitude"
                type="number"
                value="<%= burialSite.burialSiteLongitude %>"
                min="<%= configFunctions.getConfigProperty('settings.longitudeMin') %>"
                max="<%= configFunctions.getConfigProperty('settings.longitudeMax') %>"
                step="0.00000001"
                onwheel="return false"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="column">
      <div class="panel">
        <div class="panel-heading">
          <div class="level is-mobile">
            <div class="level-left">
              <div class="level-item">
                <h2 class="title is-5 has-text-weight-bold has-text-white">Image</h2>
              </div>
            </div>
            <div class="level-right">
              <div class="level-item">
                <i class="fa-solid fa-image"></i>
              </div>
            </div>
          </div>
        </div>
        <div class="panel-block is-block">
          <div class="field">
            <label class="label" for="burialSite--cemeterySvgId">
              Cemetery SVG ID
            </label>
            <div class="control">
              <input
                class="input"
                id="burialSite--cemeterySvgId"
                name="cemeterySvgId"
                type="text"
                value="<%= burialSite.cemeterySvgId %>"
                maxlength="100"
                autocomplete="off"
                pattern="^[\d\w\-]*$"
              />
            </div>
          </div>
          <div class="field">
            <label class="label" for="burialSite--burialSiteImage">Image File</label>
            <div class="control">
              <div class="select is-fullwidth">
                <select id="burialSite--burialSiteImage" name="burialSiteImage">
                  <option value="">(Select a File)</option>
                  <% for (const burialSiteImage of burialSiteImages) { %>
                  <option
                    data-selected="<%= (burialSite.burialSiteImage === burialSiteImage) ? 'selected' : '' %>"
                    value="<%= burialSiteImage %>"
                  >
                    <%= burialSiteImage %>
                  </option>
                  <% } %>
                </select>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</form>

<% if (isCreate) { %>
<div class="message is-info">
  <p class="message-body">
    Additional options will be available after the record has been created.
  </p>
</div>
<% } else { %>
<div class="panel">
  <div class="panel-heading">
    <div class="level is-mobile">
      <div class="level-left">
        <div class="level-item">
          <h2 class="has-text-weight-bold is-size-5">
            Comments
          </h2>
        </div>
      </div>
      <div class="level-right">
        <div class="level-item">
          <button class="button is-small is-success" id="burialSiteComments--add" type="button">
            <span class="icon is-small"><i class="fa-solid fa-plus"></i></span>
            <span>Add a Comment</span>
          </button>
        </div>
      </div>
    </div>
  </div>
  <div class="panel-block is-block" id="container--burialSiteComments"></div>
</div>
    
<%- include('./_viewEdit-contracts', { isEdit: true }) %>
<% } %>

<%- include('../_footerA'); -%>

<script>
  exports.bodyCapacityMaxDefault = <%- JSON.stringify(settingFunctions.getSettingValue('burialSiteTypes.bodyCapacityMaxDefault')) %>;
  exports.crematedCapacityMaxDefault = <%- JSON.stringify(settingFunctions.getSettingValue('burialSiteTypes.crematedCapacityMaxDefault')) %>;
</script>
<% if (!isCreate) { %>
<script>
    exports.burialSiteComments = <%- JSON.stringify(burialSite.burialSiteComments) %>;
</script>
<% } %>
<% if (configFunctions.getConfigProperty('settings.auditLog.enabled') && !isCreate) { %>
<script src="<%= urlPrefix %>/javascripts/record.auditLog.js"></script>
<% } %>
<script src="<%= urlPrefix %>/javascripts/burialSite.edit.js"></script>

<%- include('../_footerB'); -%>
